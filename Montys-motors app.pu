# ========== DB TABLE CREATION AND SEEDING LOGIC ==========
def db_connect():
    return sqlite3.connect(DB_FILE, check_same_thread=False)

def db_first_run_seed(conn):
    c = conn.cursor()
    # Users: username, name, hashed_password, role , email, phone
    c.execute("""
        CREATE TABLE IF NOT EXISTS users (
            username TEXT PRIMARY KEY,
            name TEXT,
            hashed_password TEXT,
            role TEXT,
            email TEXT,
            phone TEXT
        );
    """)
    # Admin user
    if c.execute("SELECT * FROM users WHERE username='greg'").fetchone() is None:
        hashed_pw = stauth.Hasher(['montys1956']).generate()[0] # will prompt for change on first login
        c.execute("INSERT INTO users VALUES (?,?,?,?,?,?)", ('greg','Greg Montoya',hashed_pw,'admin','greg@montysmotors.com',SHOP_INFO['phone']))
    # Sample tech
    if c.execute("SELECT * FROM users WHERE username='tech1'").fetchone() is None:
        hashed_pw = stauth.Hasher(['tech123']).generate()[0]
        c.execute("INSERT INTO users VALUES (?,?,?,?,?,?)", ('tech1','Joe Tech',hashed_pw,'tech','joe.tech@montysmotors.com','520-555-1234'))
    conn.commit()

    # Customers
    c.execute("""
        CREATE TABLE IF NOT EXISTS customers (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT, phone TEXT, email TEXT, vin TEXT,
            make TEXT, model TEXT, year INTEGER
        );
    """)

    # Job history
    c.execute("""
        CREATE TABLE IF NOT EXISTS job_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            customer_id INTEGER, tech_id TEXT, date TEXT,
            service TEXT, hours REAL, parts TEXT, price REAL,
            notes TEXT, status TEXT,
            FOREIGN KEY(customer_id) REFERENCES customers(id),
            FOREIGN KEY(tech_id) REFERENCES users(username)
        );
    """)

    # Appointments
    c.execute("""
        CREATE TABLE IF NOT EXISTS appointments (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            customer_id INTEGER, tech_id TEXT, date TEXT, start_time TEXT, end_time TEXT,
            service TEXT, estimated_hours REAL, status TEXT,
            FOREIGN KEY(customer_id) REFERENCES customers(id),
            FOREIGN KEY(tech_id) REFERENCES users(username)
        );
    """)

    # nhtsa_makes
    c.execute("""
        CREATE TABLE IF NOT EXISTS nhtsa_makes (
            make_id INTEGER PRIMARY KEY,
            make_name TEXT
        );
    """)

    # nhtsa_models
    c.execute("""
        CREATE TABLE IF NOT EXISTS nhtsa_models (
            model_id INTEGER PRIMARY KEY AUTOINCREMENT,
            make_id INTEGER,
            make_name TEXT,
            model_name TEXT
        );
    """)

    # epa_fuel
    c.execute("""
        CREATE TABLE IF NOT EXISTS epa_fuel (
            id INTEGER PRIMARY KEY,
            year INTEGER,
            make TEXT,
            model TEXT,
            mpg_city REAL,
            mpg_highway REAL,
            fuel_type TEXT
        );
    """)

    # recalls
    c.execute("""
        CREATE TABLE IF NOT EXISTS recalls (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            NHTSA_ID TEXT,
            vin TEXT,
            make TEXT,
            model TEXT,
            year INTEGER,
            recall_desc TEXT,
            recall_date TEXT
        );
    """)

    # repair_resources (diagrams/manuals/TSBs)
    c.execute("""
        CREATE TABLE IF NOT EXISTS repair_resources (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            make TEXT,
            model TEXT,
            year INTEGER,
            resource_type TEXT,
            resource_link TEXT,
            resource_desc TEXT
        );
    """)

    # shop_notes
    c.execute("""
        CREATE TABLE IF NOT EXISTS shop_notes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            date TEXT,
            note TEXT,
            author TEXT
        );
    """)

    # parts_prices
    c.execute("""
        CREATE TABLE IF NOT EXISTS parts_prices (
            part_number TEXT PRIMARY KEY,
            name TEXT,
            brand TEXT,
            price REAL,
            stock INTEGER,
            last_updated TEXT
        );
    """)

    # inventory
    c.execute("""
        CREATE TABLE IF NOT EXISTS inventory (
            part_number TEXT PRIMARY KEY,
            name TEXT, brand TEXT, quantity INTEGER,
            reorder_level INTEGER, supplier TEXT, cost REAL
        );
    """)

    # inventory_transactions
    c.execute("""
        CREATE TABLE IF NOT EXISTS inventory_transactions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            part_number TEXT,
            change INTEGER,
            date TEXT,
            user TEXT,
            reason TEXT
        );
    """)

    # supplier_orders
    c.execute("""
        CREATE TABLE IF NOT EXISTS supplier_orders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            date TEXT,
            supplier TEXT,
            status TEXT,
            items_json TEXT,
            tracking TEXT
        );
    """)

    # invoices
    c.execute("""
        CREATE TABLE IF NOT EXISTS invoices (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            customer_id INTEGER,
            job_id INTEGER,
            qb_invoice_id TEXT,
            date TEXT,
            total REAL,
            status TEXT,
            pdf_link TEXT,
            qb_template_id TEXT,
            FOREIGN KEY(customer_id) REFERENCES customers(id),
            FOREIGN KEY(job_id) REFERENCES job_history(id)
        );
    """)
    conn.commit()

    # NHTSA API seed if first run
    seed_nhtsa_makes_models(conn)
    # EPA fuel data if first run
    seed_epa_fuel(conn)
    # Recalls data
    seed_recalls(conn)
    conn.commit()

def seed_nhtsa_makes_models(conn):
    """Download makes/models from NHTSA and seed tables."""
    c = conn.cursor()
    # Only run if not seeded yet
    makes_count = c.execute("SELECT COUNT(*) FROM nhtsa_makes").fetchone()[0]
    if makes_count > 50: return
    try:
        r = requests.get("https://vpic.nhtsa.dot.gov/api/vehicles/GetAllMakes?format=json", timeout=15)
        data = r.json()["Results"]
        makes = []
        for row in data:
            makes.append( (row["MakeId"], row["MakeName"]) )
        c.executemany("INSERT INTO nhtsa_makes VALUES (?, ?)", makes)

        # Models per make (top 50 makes to avoid overload)
        for make in makes[:50]:
            make_id, make_name = make
            r2 = requests.get(f"https://vpic.nhtsa.dot.gov/api/vehicles/GetModelsForMake/{make_name}?format=json", timeout=15)
            models = r2.json()['Results']
            for m in models:
                c.execute(
                    "INSERT INTO nhtsa_models (make_id, make_name, model_name) VALUES (?, ?, ?)",
                    (make_id, make_name, m["Model_Name"])
                )
    except Exception as e:
        st.warning("Failed to seed NHTSA makes/models: " + str(e))
    conn.commit()

def seed_epa_fuel(conn):
    """Download, parse EPA fuel data ZIP, load to epa_fuel."""
    c = conn.cursor()
    if c.execute("SELECT COUNT(*) FROM epa_fuel").fetchone()[0] > 0:
        return
    url = "https://www.fueleconomy.gov/feg/epadata/26data.zip"
    try:
        r = requests.get(url, timeout=20)
        with zipfile.ZipFile(io.BytesIO(r.content)) as zf:
            for name in zf.namelist():
                if name.endswith("2026.csv"): # Only 2026 file
                    with zf.open(name) as f:
                        df = pd.read_csv(f, encoding="utf8")
                        for idx, row in df.iterrows():
                            c.execute("""
                              INSERT OR IGNORE INTO epa_fuel (
                                id, year, make, model, mpg_city, mpg_highway, fuel_type
                              ) VALUES (?, ?, ?, ?, ?, ?, ?)
                            """, (
                                idx,
                                row.get('year',2026),
                                row.get('make',''),
                                row.get('model',''),
                                row.get('city08',0),
                                row.get('highway08',0),
                                row.get('fuelType','')
                            ))
    except Exception as e:
        st.warning("EPA fuel data error: " + str(e))
    conn.commit()

def seed_recalls(conn):
    """Download, parse NHTSA recalls since 2010, load to recalls table."""
    c = conn.cursor()
    if c.execute("SELECT COUNT(*) FROM recalls").fetchone()[0] > 0: return
    url = "https://static.nhtsa.gov/odi/ffdd/rcl/FLAT_RCL_POST_2010.zip"
    try:
        r = requests.get(url, timeout=20)
        with zipfile.ZipFile(io.BytesIO(r.content)) as zf:
            for name in zf.namelist():
                if "FLAT_RCL_POST_2010" in name and name.endswith(".csv"):
                    with zf.open(name) as f:
                        df = pd.read_csv(f, encoding="utf8")
                        # Only import first 1000 for speed
                        for idx, row in df.head(1000).iterrows():
                            c.execute("""
                              INSERT INTO recalls (
                                NHTSA_ID, vin, make, model, year, recall_desc, recall_date
                              ) VALUES (?, ?, ?, ?, ?, ?, ?)""", (
                                str(row.get('NHTSA_ID','')),
                                str(row.get('VIN','')),
                                str(row.get('MAKE','')),
                                str(row.get('MODEL','')),
                                int(row.get('MY','2026')),
                                str(row.get('RCL_DESC','')),
                                str(row.get('RC_DATE',''))
                            ))
    except Exception as e:
        st.warning("Recall data error: " + str(e))
    conn.commit()

def get_db_conn():
    """Returns DB connection and seeds tables if needed."""
    if not os.path.exists(DB_FILE):
        conn = db_connect()
        db_first_run_seed(conn)
    else:
        conn = db_connect()
    return conn

# ========== AUTHENTICATION CONFIG ==========
def get_auth_config(conn):
    c = conn.cursor()
    users = c.execute("SELECT username, name, role, email, phone, hashed_password FROM users").fetchall()
    usernames = [u[0] for u in users]
    names = [u[1] for u in users]
    roles = [u[2] for u in users]
    emails = [u[3] for u in users]
    phones = [u[4] for u in users]
    passwords = [u[5] for u in users]
    return {
        'credentials': {
            'usernames': {
                u: {
                    'email': e,
                    'name': n,
                    'password': p,
                    'role': r
                } for u, n, r, e, p in zip(usernames, names, roles, emails, passwords)
            }
        },
        'cookie': {
            'name': 'montysmotorsauth',
            'key': 'abcdef',
            'expiry_days': 2
        },
        'pre_auth': {
            'email': True
        }
    }

# ========== APP MAIN ==========
def main():
    st.set_page_config(page_title=SHOP_INFO["name"], page_icon="🔧", layout="wide")
    st.title(f"Monty's Motors – Since 1956")
    st.caption(SHOP_INFO['slogan'])
    # Footer is sticky at bottom with shop info

    conn = get_db_conn()
    auth_config = get_auth_config(conn)

    # Authenticator setup
    authenticator = stauth.Authenticate(
        auth_config['credentials'],
        auth_config['cookie']['name'],
        auth_config['cookie']['key'],
        auth_config['cookie']['expiry_days']
    )

    name, auth_status, username = authenticator.login('Login', 'main')
    if auth_status is False:
        st.error("Incorrect username or password")
        st.stop()
    elif auth_status is None:
        st.info("Please enter your credentials")
        st.stop()

    user_role = auth_config['credentials']['usernames'][username]['role']

    # Force admin password change on first login
    if username == 'greg' and stauth.Hasher(['montys1956']).check(auth_config['credentials']['usernames']['greg']['password']):
        st.warning("Admin must change default password now.")
        new_pw = st.text_input("New admin password", type='password')
        if st.button("Update password"):
            if new_pw and len(new_pw) > 6:
                new_hash = stauth.Hasher([new_pw]).generate()[0]
                conn.execute("UPDATE users SET hashed_password=? WHERE username='greg'", (new_hash,))
                conn.commit()
                st.success("Admin password changed.")
                st.experimental_rerun()
            else:
                st.error("Password too short.")
        st.stop()

    authenticator.logout('Logout', 'sidebar')
    st.sidebar.markdown(f"""
        **Shop Contact:**  
        {SHOP_INFO['address']}  
        {SHOP_INFO['phone']}  
        [Website]({SHOP_INFO['website']})  
        **Logged in:** {name} ({username}) [{user_role}]
    """)
    st.sidebar.markdown("---")

    # ========== MENU ==========
    tabs_admin = [
        "Dashboard", "AI Chat", "Schedule", "Customers",
        "Inventory", "Orders", "Invoices", "Resources"
    ]
    tabs_tech = ["AI Chat", "My Workload", "Resources"]

    if user_role == "admin":
        selected = st.sidebar.radio("Main Menu", tabs_admin)
    else:
        selected = st.sidebar.radio("Main Menu", tabs_tech)

    # ========== PAGES ==========
    if selected == "Dashboard":
        admin_dashboard(conn)
    elif selected == "AI Chat":
        ai_chat_page(username, user_role, conn)
    elif selected == "My Workload":
        tech_workload_page(username, conn)
    elif selected == "Customers":
        customers_page(conn)
    elif selected == "Inventory":
        inventory_page(conn, user_role)
    elif selected == "Orders":
        orders_page(conn, user_role)
    elif selected == "Invoices":
        invoices_page(conn, user_role)
    elif selected == "Schedule":
        schedule_page(conn, user_role, username)
    elif selected == "Resources":
        resources_page(conn)
    # ========== FOOTER ==========
    st.markdown("<hr/>", unsafe_allow_html=True)
    st.markdown(f"<center><small>{SHOP_INFO['footer']}</small></center>", unsafe_allow_html=True)

# ========== DASHBOARD ==========
def admin_dashboard(conn):
    st.header("Admin Dashboard")
    c = conn.cursor()
    total_customers = c.execute("SELECT COUNT(*) FROM customers").fetchone()[0]
    total_jobs = c.execute("SELECT COUNT(*) FROM job_history").fetchone()[0]
    inventory_low = c.execute("SELECT COUNT(*) FROM inventory WHERE quantity <= reorder_level").fetchone()[0]
    total_invoices = c.execute("SELECT COUNT(*) FROM invoices").fetchone()[0]
    st.subheader("Overview")
    col1, col2, col3, col4 = st.columns(4)
    col1.metric("Customers", total_customers)
    col2.metric("Jobs", total_jobs)
    col3.metric("Low Inventory", inventory_low)
    col4.metric("Invoices", total_invoices)
    st.subheader("Quick Links")
    st.markdown("""
    - [Customer List](#customers)
    - [Inventory Orders](#orders)
    """)
    st.subheader("Add Tech User")
    with st.form("add_user"):
        uname = st.text_input("Username")
        fname = st.text_input("Full Name")
        email = st.text_input("Email")
        phone = st.text_input("Phone")
        role = st.selectbox("Role", ["tech"])
        pw = st.text_input("Password", type='password')
        if st.form_submit_button("Add User"):
            if all([uname, fname, email, phone, pw]):
                hash_pw = stauth.Hasher([pw]).generate()[0]
                conn.execute("INSERT INTO users VALUES (?,?,?,?,?,?)", (uname, fname, hash_pw, role, email, phone))
                conn.commit()
                st.success("Tech user created.")
            else:
                st.warning("All fields required.")

# ========== AI CHAT PAGE ==========
def ai_chat_page(username, role, conn):
    st.header("Shop AI Chatbot – Ask Anything!")
    st.info("Specs, MPG, recalls, diagrams, PartsTech pricing, step-by-step help. Honest answers. VIN decode auto.")
    if role != 'admin':
        st.caption("*Techs: For low inventory or ordering, check with Greg.*")
    query = st.text_input("Type your question here:")
    if query:
        with st.spinner("AI thinking..."):
            answer = ai_chat(query, username, role, conn)
            st.markdown(answer)

def ai_chat(query, username, role, conn):
    """LangChain + OpenAI, pulls data as needed, honest tone."""
    # Basic context/intent detection
    c = conn.cursor()
    response = ""

    # VIN decode
    import re
    vin_match = re.search(r'\b([A-HJ-NPR-Z0-9]{17})\b', query.upper())
    if vin_match:
        vin = vin_match.group(1)
        r = requests.get(f"https://vpic.nhtsa.dot.gov/api/vehicles/DecodeVin/{vin}?format=json")
        decode_list = r.json()['Results']
        decode = {el['Variable']: el['Value'] for el in decode_list}
        response += f"**VIN Decode:**\n"
        for k in ['Make','Model','Model Year','Trim','Engine Model','Vehicle Type']:
            if decode.get(k):
                response += f"- {k}: {decode.get(k)}\n"

        # Pull customer/job history if found
        cust = c.execute("SELECT name, phone, email, make, model, year FROM customers WHERE vin=?", (vin,)).fetchone()
        if cust:
            response += f"\n**Customer History:** {cust}\n"
            jobs = c.execute("SELECT date, service, price FROM job_history WHERE customer_id=(SELECT id FROM c
